generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
}

enum Language {
  BG
  EN
}

enum StudyTopicStatus {
  DRAFT
  GENERATED
  ARCHIVED
}

model User {
  id                     Int                      @id @default(autoincrement())
  name                   String
  email                  String                   @unique
  passwordHash           String
  role                   Role                     @default(STUDENT)
  languagePreference     Language                 @default(BG)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  studyTopics            StudyTopic[]
  quizAttempts           QuizAttempt[]
  notificationPreference NotificationPreference?
  activityLogs           ActivityLog[]

  @@map("users")
}

model StudyTopic {
  id           Int              @id @default(autoincrement())
  userId       Int
  title        String
    originalText String?        @db.LongText
    ocrText      String?        @db.LongText
    finalText    String?        @db.LongText
  language     Language         @default(BG)
  status       StudyTopicStatus @default(DRAFT)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiResult     AIResult?
  quizAttempts QuizAttempt[]

  @@index([userId])
  @@map("study_topics")
}

model AIResult {
  id             Int        @id @default(autoincrement())
  topicId        Int        @unique
  summary        String     @db.Text
  keyTerms       Json
  studyPlan      Json
  flashcardsJson Json
  quizJson       Json
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  topic          StudyTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("ai_results")
}

model QuizAttempt {
  id             Int        @id @default(autoincrement())
  userId         Int
  topicId        Int
  score          Int
  totalQuestions Int
  answersJson    Json
  createdAt      DateTime   @default(now())

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          StudyTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([topicId])
  @@map("quiz_attempts")
}

model NotificationPreference {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  enabled       Boolean  @default(false)
  preferredTime String   @default("09:00")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  details   Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("activity_logs")
}